---
import { Icon } from "astro-icon/components";

// Card.astro
interface Props {
  title: string;
  description: string;
  link: string;
  type: "url" | "instar" | "youtube" | "tool";
}

const { title, description, link, type } = Astro.props;
---

<a href={link} target="_blank" class="redirect-card">
  <h5 class="redirect-card-title">
    {title}
  </h5>
  {
    type === "instar" && (
      <div class="redirect-type">
        <Icon name="mdi:instagram" class="icon-pink" />
        <span class="type-label">Instagram</span>
      </div>
    )
  }
  {
    type === "url" && (
      <Icon name="mdi:link-box-variant-outline" class="redirect-icon" />
    )
  }
  {
    type === "youtube" && (
      <div class="redirect-type">
        <Icon name="mdi:youtube" class="icon-red" />
        <span class="type-label">YouTube</span>
      </div>
    )
  }
  {type === "tool" && <Icon name="mdi:tools" class="redirect-icon" />}
  <p class="redirect-desc">{description}</p>
</a>

<style>
  .redirect-card {
    display: block;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 16px;
    padding: 1.5rem;
    text-decoration: none;
    color: #fff;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
  }

  .redirect-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.06) 0%,
      transparent 40%
    );
    pointer-events: none;
  }

  .redirect-card:hover {
    transform: translateY(-4px) scale(1.01);
    background: rgba(255, 255, 255, 0.07);
    border-color: rgba(136, 58, 234, 0.5);
    box-shadow:
      0 12px 30px -10px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(136, 58, 234, 0.3);
  }

  .redirect-card-title {
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0 0 0.75rem 0;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .redirect-type {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin-bottom: 0.5rem;
  }

  .type-label {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  .redirect-icon {
    width: 1.25rem;
    height: 1.25rem;
    color: var(--accent, #b388ff);
    margin-bottom: 0.5rem;
    display: block;
  }

  .icon-pink {
    width: 1.25rem;
    height: 1.25rem;
    color: #ec4899;
  }

  .icon-red {
    width: 1.25rem;
    height: 1.25rem;
    color: #ef4444;
  }

  .redirect-desc {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    margin: 0;
    line-height: 1.6;
    transition: color 0.2s ease;
  }

  .redirect-card:hover .redirect-desc {
    color: rgba(255, 255, 255, 0.85);
  }
</style>
