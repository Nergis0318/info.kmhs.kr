---
export const prerender = true;

// Props interface
interface Props {
  title: string;
  body: string;
  href: string;
  class?: string;
}

const { href, title, body, class: className } = Astro.props;
---

<li class={`link-card ${className}`}>
  <a href={href}>
    <h2 class="card-title">
      {title}
      <span>&rarr;</span>
    </h2>
    <p>
      {body}
    </p>
  </a>
</li>
<style>
  :root {
    --primary-color: #883aea;
    --text-light: #ffffff;
  }

  .link-card {
    list-style: none;
    display: flex;
    padding: 0;
    background: rgba(255, 255, 255, 0.03);
    border-radius: 16px;
    position: relative;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.1),
      0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  /* Glass reflection effect */
  .link-card::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.1) 0%,
      transparent 40%,
      transparent 60%,
      rgba(255, 255, 255, 0.05) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .link-card > a {
    text-decoration: none;
    line-height: 1.5;
    padding: 1.5rem;
    border-radius: 16px;
    width: 100%;
    color: var(--text-light);
    display: flex;
    flex-direction: column;
    height: 100%;
    z-index: 1;
    position: relative;
  }

  .link-card > a > p {
    color: rgba(255, 255, 255, 0.7);
    margin-top: 0.5rem;
    font-size: 0.95rem;
    flex-grow: 1;
    transition: color 0.3s ease;
  }

  .card-title {
    margin: 0;
    font-size: 1.4rem;
    font-weight: 700;
    color: #fff;
    display: flex;
    justify-content: space-between;
    align-items: center;
    letter-spacing: -0.02em;
  }

  .card-title span {
    transition: transform 0.3s ease;
    opacity: 0.7;
    color: var(--primary-color);
  }

  /* Hover Effects */
  .link-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.08); /* Brighter glass */
    box-shadow:
      0 12px 24px -10px rgba(0, 0, 0, 0.5),
      0 0 0 1px rgba(136, 58, 234, 0.4); /* Point color border */
    border-color: rgba(136, 58, 234, 0.6);
  }

  .link-card:hover .card-title span {
    transform: translateX(5px);
    opacity: 1;
  }

  .link-card:hover > a > p {
    color: rgba(255, 255, 255, 0.95);
  }
</style>
