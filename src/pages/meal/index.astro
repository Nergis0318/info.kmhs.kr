---
import Layout from "../../layouts/Layout.astro";
import ScrollToTopButton from "../../components/ScrollToTopButton.astro";
import { Image } from "astro:assets";
---

<Layout title="급식 조회" description="급식표">
  <main class="jetbrains-theme-page" style="max-width: 800px;">
    <h1 class="page-title">급식 정보</h1>

    <div id="loading-indicator" class="meal-loading">
      <strong>불러오는 중...</strong>
    </div>

    <div class="glass-card">
      <h5 class="allergy-title">알레르기정보</h5>
      <hr class="glass-divider" />
      <p id="allergy-info" class="allergy-content" style="display: none;">
        1.난류<br />2.우유<br />3.메밀<br />4.땅콩<br />5.대두<br />6.밀<br
        />7.고등어<br />8.게<br />9.새우<br />10.돼지고기<br />11.복숭아<br
        />12.토마토<br />13.아황산염<br />14.호두<br />15.닭고기<br
        />16.소고기<br />17.오징어<br />18.조개류(굴,전복,홍합 포함)<br />19.잣
      </p>
      <div class="allergy-buttons">
        <button
          class="month-button"
          id="show-button"
          onclick="document.getElementById('allergy-info').style.display = 'block'; this.style.display = 'none'; document.getElementById('hide-button').style.display = 'inline';"
          >더보기</button
        >
        <button
          id="hide-button"
          class="month-button"
          style="display: none;"
          onclick="document.getElementById('allergy-info').style.display = 'none'; this.style.display = 'none'; document.getElementById('show-button').style.display = 'inline';"
          >접기</button
        >
      </div>
    </div>

    <div id="today-meal-container" class="meal-container"></div>
    <div id="tomorrow-meal-container" class="meal-container"></div>

    <div class="month-nav">
      {
        Array.from({ length: 12 }).map((_, i) => (
          <button id={`month-button-${i + 1}`} class="month-button">
            {i + 1}월
          </button>
        ))
      }
    </div>

    <ul id="meals-list" class="meals-list"></ul>

    <ScrollToTopButton />

    <style>
      .meal-loading {
        text-align: center;
        padding: 2rem;
        color: rgba(255, 255, 255, 0.6);
        font-size: 1.1rem;
      }
      .allergy-title {
        text-align: center;
        font-size: 1.1rem;
        font-weight: 700;
        margin: 0 0 0.75rem 0;
      }
      .glass-divider {
        border: none;
        border-top: 1px solid rgba(255, 255, 255, 0.1);
        margin: 0.5rem 0;
      }
      .allergy-content {
        color: rgba(255, 255, 255, 0.75);
        line-height: 1.8;
        margin: 0.75rem 0 0 0;
      }
      .allergy-buttons {
        margin-top: 0.75rem;
        text-align: center;
      }
      .meal-container {
        margin-bottom: 1.5rem;
      }
      .month-nav {
        text-align: center;
        margin-bottom: 1.5rem;
      }
      .meals-list {
        list-style: none;
        padding: 0;
        margin: 0;
      }
      .cal-info {
        font-weight: bold;
        color: rgba(255, 255, 255, 0.6);
        font-size: 0.9rem;
      }
      .menu-info {
        margin-top: 0.5rem;
        white-space: pre-line;
        color: rgba(255, 255, 255, 0.85);
        line-height: 1.8;
      }
    </style>

    <script>
      async function fetchMeals() {
        const currentYear = new Date().getFullYear();
        const fromDate = `${currentYear}0101`;
        const toDate = `${currentYear}1231`;

        const cacheKey = `meals_${currentYear}`;
        const cachedData = localStorage.getItem(cacheKey);

        if (cachedData) {
          const { data, timestamp } = JSON.parse(cachedData);
          // 1일(24시간) 동안 캐시 유지
          if (new Date().getTime() - timestamp < 24 * 60 * 60 * 1000) {
            return data;
          }
        }

        const response = await fetch(
          `https://open.neis.go.kr/hub/mealServiceDietInfo?KEY=4e1af35dc1954eb8aaf573eff8653c43&Type=json&ATPT_OFCDC_SC_CODE=J10&SD_SCHUL_CODE=7531381&MLSV_FROM_YMD=${fromDate}&MLSV_TO_YMD=${toDate}&pSize=365`,
        );
        const data = await response.json();
        const rowData = data.mealServiceDietInfo[1].row;

        try {
          localStorage.setItem(
            cacheKey,
            JSON.stringify({
              data: rowData,
              timestamp: new Date().getTime(),
            }),
          );
        } catch (e) {
          console.error("Local storage error:", e);
        }

        return rowData;
      }

      async function fetchMealImage() {
        try {
          const controller = new AbortController();
          const timeoutId = setTimeout(() => controller.abort(), 10000);

          const response = await fetch("https://api.INFO.KMHS.KR/mealimg", {
            signal: controller.signal,
          });

          clearTimeout(timeoutId);

          if (response.status === 404) {
            return null;
          }
          return response.text();
        } catch (error) {
          console.error("Error fetching meal image:", error);
          return null;
        }
      }

      function formatDate(dateString: string) {
        const date = new Date(
          dateString.slice(0, 4) +
            "-" +
            dateString.slice(4, 6) +
            "-" +
            dateString.slice(6, 8),
        );
        return date.toLocaleDateString("ko-KR", {
          year: "numeric",
          month: "long",
          day: "numeric",
        });
      }

      async function renderMeal(
        containerId: string,
        meal: any,
        title: string,
        bgColor: string,
        imageUrl: string | null | "loading",
      ) {
        const container = document.getElementById(containerId) as HTMLElement;
        if (meal) {
          container.innerHTML = `
                    <div style="background:rgba(255,255,255,0.03);backdrop-filter:blur(12px);border:2px solid ${bgColor};border-radius:16px;padding:1.5rem;margin-bottom:1.5rem;">
                        <h2 style="font-size:1.5rem;font-weight:700;text-align:center;margin:0 0 0.75rem;color:${bgColor};">${title}</h2>
                        <h5 style="font-size:1rem;font-weight:600;color:rgba(255,255,255,0.9);margin:0 0 0.5rem;">${formatDate(meal.MLSV_YMD)}</h5>
                        <p class="cal-info">&bull; 칼로리: ${meal.CAL_INFO}</p>
                        <hr style="border:none;border-top:1px solid rgba(255,255,255,0.1);margin:0.75rem 0;">
                        <p class="menu-info">${meal.DDISH_NM.replace(/<br\/>/g, "<br />").replace(/\(근명\)/g, "")}</p>
                        <div id="${containerId}-image-slot">${renderMealImage(imageUrl)}</div>
                        <button class="copy-menu-button primary-button" style="margin-top:1rem;">메뉴 복사</button>
                    </div>
                `;
          const copyButton = container.querySelector(
            ".copy-menu-button",
          ) as HTMLButtonElement;
          copyButton.addEventListener("click", () => {
            const menuInfo = meal.DDISH_NM.replace(/<br\/>/g, "\n").replace(
              /\(근명\)/g,
              "",
            );
            navigator.clipboard.writeText(menuInfo).then(() => {
              alert("메뉴가 복사되었습니다.");
            });
          });
        } else {
          container.innerHTML = `
                    <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:16px;padding:1.5rem;margin-bottom:1.5rem;text-align:center;">
                        <h2 style="font-size:1.5rem;font-weight:700;margin:0 0 0.5rem;">${title} 정보가 없습니다</h2>
                        <p style="color:rgba(255,255,255,0.6);">${title} 정보가 제공되지 않았습니다. 다른 날짜를 확인해 주세요.</p>
                    </div>
          `;
        }
      }

      function renderMealImage(imageUrl: string | null | "loading") {
        if (imageUrl === "None") {
          return "";
        }

        if (imageUrl === "loading") {
          return `<p style="text-align:center;color:rgba(255,255,255,0.5);margin-top:1rem;">급식 사진을 불러오는 중입니다.</p>`;
        }

        if (imageUrl) {
          return `<img src="${imageUrl}" alt="Meal Image" style="width:100%;height:auto;margin-top:1rem;border-radius:12px;" loading="lazy" />`;
        }

        return `<p style="text-align:center;color:rgba(255,255,255,0.5);margin-top:1rem;">급식 사진이 아직 업로드되지 않았습니다.</p>`;
      }

      function updateMealImage(containerId: string, imageUrl: string | null) {
        const imageSlot = document.getElementById(`${containerId}-image-slot`);
        if (imageSlot) {
          imageSlot.innerHTML = renderMealImage(imageUrl);
        }
      }

      function renderMealsList(meals: any[]) {
        const mealsList = document.getElementById("meals-list") as HTMLElement;
        mealsList.innerHTML = meals
          .map(
            (meal) => `
                <li style="background:rgba(255,255,255,0.03);border:1px solid rgba(255,255,255,0.08);border-radius:12px;padding:1.25rem;margin-bottom:1rem;" data-month="${new Date(meal.MLSV_YMD.slice(0, 4) + "-" + meal.MLSV_YMD.slice(4, 6) + "-" + meal.MLSV_YMD.slice(6, 8)).getMonth() + 1}">
                    <h5 style="font-size:1rem;font-weight:600;color:rgba(255,255,255,0.9);margin:0 0 0.4rem;">${formatDate(meal.MLSV_YMD)}</h5>
                    <p class="cal-info">&bull; 칼로리: ${meal.CAL_INFO}</p>
                    <hr style="border:none;border-top:1px solid rgba(255,255,255,0.08);margin:0.6rem 0;">
                    <p class="menu-info" style="font-size:0.9rem;">${meal.DDISH_NM.replace(/<br\/>/g, "<br />").replace(/\(근명\)/g, "")}</p>
                </li>
            `,
          )
          .join("");
      }

      function scrollToMonth(month: number) {
        const eventElement = document.querySelector(`[data-month="${month}"]`);
        if (eventElement) {
          eventElement.scrollIntoView({ behavior: "smooth" });
        }
      }

      document.addEventListener("DOMContentLoaded", async () => {
        const loadingIndicator = document.getElementById(
          "loading-indicator",
        ) as HTMLElement;
        loadingIndicator.style.display = "block";

        const meals = await fetchMeals();
        loadingIndicator.style.display = "none";

        const today = new Date();
        const todayString = `${today.getFullYear()}${String(today.getMonth() + 1).padStart(2, "0")}${String(today.getDate()).padStart(2, "0")}`;
        //@ts-ignore
        const todayMeal = meals.find((meal) => meal.MLSV_YMD === todayString);

        const tomorrow = new Date(today);
        tomorrow.setDate(today.getDate() + 1);
        const tomorrowString = `${tomorrow.getFullYear()}${String(tomorrow.getMonth() + 1).padStart(2, "0")}${String(tomorrow.getDate()).padStart(2, "0")}`;
        const tomorrowMeal = (meals as any[]).find(
          (meal: { MLSV_YMD: string }) => meal.MLSV_YMD === tomorrowString,
        );

        renderMeal(
          "today-meal-container",
          todayMeal,
          "오늘의 급식",
          "#b388ff",
          "loading",
        );
        renderMeal(
          "tomorrow-meal-container",
          tomorrowMeal,
          "내일 급식",
          "#6ee7b7",
          "None",
        );
        renderMealsList(meals as any[]);

        Array.from({ length: 12 }, (_, i) => {
          const button = document.getElementById(`month-button-${i + 1}`);
          if (button) {
            button.addEventListener("click", () => scrollToMonth(i + 1));
          }
        });

        fetchMealImage().then((imageUrl) => {
          updateMealImage("today-meal-container", imageUrl);
        });
      });
    </script>
  </main>
</Layout>
