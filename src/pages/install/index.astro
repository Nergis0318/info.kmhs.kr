---
import Layout from "../../layouts/Layout.astro";
import { Icon } from "astro-icon/components";
---

<Layout title="설치 페이지" description="INFO.KMHS.KR를 간단하게 설치해보세요!">
  <main class="jetbrains-theme-page">
    <h1 class="page-title">INFO.KMHS.KR 설치</h1>
    <div class="glass-card">
      <h4 style="font-size: 1.4rem; font-weight: 700; margin: 0 0 1rem 0; color: var(--accent, #b388ff);">Android</h4>
      <p style="color: rgba(255,255,255,0.7); margin-bottom: 1rem;">아래 버튼을 눌러 앱으로 설치하세요.</p>
      <button
        id="installButton"
        class="primary-button"
        ><Icon name="mdi:arrow-down-box" style="width: 1.2rem; height: 1.2rem;" /> 앱으로 설치하기</button
      >
    </div>
    <div class="glass-card">
      <h4 style="font-size: 1.4rem; font-weight: 700; margin: 0 0 1rem 0; color: var(--accent, #b388ff);">iOS</h4>
      <p style="color: rgba(255,255,255,0.75); line-height: 1.8;">
        <Icon name="mdi:ios-share" class="inline-block" style="width: 1.2rem; height: 1.2rem; vertical-align: -0.2rem;" /> 버튼을 눌러 <strong>홈 화면에 추가하기</strong>를 통해 설치하세요.
      </p>
    </div>
  </main>
  <script is:inline type="module">
    let deferredPrompt;
    const installButton = document.getElementById("installButton");
    // noinspection SpellCheckingInspection
    window.addEventListener("beforeinstallprompt", (e) => {
      e.preventDefault();
      deferredPrompt = e;
      // noinspection JSUnresolvedReference
      installButton.style.display = "block";
    });
    installButton.addEventListener("click", async () => {
      if (deferredPrompt) {
        await deferredPrompt.prompt();
        deferredPrompt = null;
      }
    });
  </script>
</Layout>
