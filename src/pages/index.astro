---
import Layout from "../layouts/Layout.astro";
import Card from "../components/IndexCard.astro";
import Beams from "../components/Beams.tsx";
---

<Layout title="INFO.KMHS.KR" description="근명고등학교 정보를 제공합니다.">
  <main class="jetbrains-theme">
    <header class="header-container">
      <div class="beams-background">
        <Beams
          client:load
          beamWidth={3}
          beamHeight={30}
          beamNumber={20}
          lightColor="#b281ef"
          speed={2}
          noiseIntensity={1.75}
          scale={0.2}
          rotation={30}
        />
      </div>
      <div class="header-content">
        <h1>
          Welcome to <span class="gradient-text">INFO.KMHS.KR</span>
        </h1>
        <p class="sub-heading">근명고등학교 학생들을 위한 정보 서비스</p>
      </div>
    </header>
    <section class="feature-grid">
      <Card
        class="card"
        href="/meal"
        title="🍱 급식"
        body="오늘과 내일의 급식 정보를 확인하세요."
      />
      <Card
        class="card"
        href="/timetable"
        title="🕒 시간표"
        body="학교 시간표를 손쉽게 확인하세요."
      />
      <Card
        class="card"
        href="/academic_calendar"
        title="🎓 학사일정"
        body="학사일정을 빠르게 확인하세요."
      />
      <Card
        class="card"
        href="/install"
        title="⬇️ 설치"
        body="이 사이트를 앱으로 설치해보세요."
      />
      <Card
        class="card"
        href="/about"
        title="ℹ️ About"
        body="해당 사이트에 대해 알아보세요."
      />
    </section>
    <footer>
      <p class="footer-text">
        <strong>INFO.KMHS.KR</strong>는 항상 여러분과 함께합니다. 도움이
        필요하면 이메일로 문의하세요: <a
          href="mailto:me@nergis.dev"
          class="email-link">me@nergis.dev</a
        >
      </p>
    </footer>
  </main>
</Layout>

<style>
  .jetbrains-theme {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    position: relative;
    z-index: 1;
  }

  .header-container {
    background: rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    text-align: center;
    padding: 5rem 1rem 3rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    position: relative;
    overflow: hidden;
  }

  .beams-background {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 100%;
    height: 600px;
    z-index: 0;
    pointer-events: none;
    mask-image: linear-gradient(
      to bottom,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
    -webkit-mask-image: linear-gradient(
      to bottom,
      transparent,
      black 15%,
      black 85%,
      transparent
    );
  }

  .header-content {
    position: relative;
    z-index: 1;
  }

  .header-container h1 {
    font-size: 3.5rem;
    font-weight: 800;
    margin: 0;
    letter-spacing: -0.03em;
    text-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  }

  .gradient-text {
    background: linear-gradient(135deg, #fff 0%, var(--primary) 100%);
    background-clip: text;
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .sub-heading {
    color: rgba(255, 255, 255, 0.6);
    margin-top: 1rem;
    font-size: 1.2rem;
    font-weight: 400;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    padding: 4rem 2rem;
    max-width: 1400px;
    margin: 0 auto;
    width: 100%;
    box-sizing: border-box;
  }

  footer {
    background: rgba(0, 0, 0, 0.2);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: rgba(255, 255, 255, 0.4);
    padding: 3rem 2rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    margin-top: auto;
    font-size: 0.9rem;
  }

  footer strong {
    color: #fff;
    font-weight: 600;
  }

  footer .email-link {
    color: var(--primary);
    text-decoration: none;
    font-weight: bold;
    transition:
      color 0.3s,
      text-shadow 0.3s;
    position: relative;
    margin-left: 0.5rem;
  }

  footer .email-link:hover {
    color: #fff;
    text-shadow: 0 0 15px var(--primary);
  }
</style>
