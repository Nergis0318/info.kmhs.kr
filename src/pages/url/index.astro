---
import Layout from "../../layouts/Layout.astro";
import Card from "../../components/RedirectCard.astro";
import links from "../../assets/url-url.json";
---

<Layout title="유용한 링크 모음" description="유용한 링크 모음">
  <main class="jetbrains-theme-page" style="max-width: 1200px;">
    <h1 class="page-title">유용한 링크 모음</h1>
    <div class="redirect-grid">
      {
        links.map((link) => (
          //@ts-ignore
          <Card
            title={link.title}
            description={link.description}
            link={link.link}
            type={link.type}
          />
        ))
      }
    </div>
  </main>
  <style>
    .redirect-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 1.25rem;
    }
  </style>
</Layout>
