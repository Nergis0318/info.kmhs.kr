---
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="시간표 조회"
  description="학년과 반을 선택하여 시간표를 조회하세요"
>
  <main
    class="mx-auto w-full max-w-4xl p-4 text-lg leading-relaxed text-black dark:bg-gray-800 dark:text-white"
  >
    <h1 class="mb-4 text-center text-4xl font-bold">시간표 조회</h1>
    <div class="mb-4">
      <label for="grade" class="mb-2 block">학년:</label>
      <select
        id="grade"
        class="w-full border p-2 dark:bg-gray-800 dark:text-gray-100"
      >
        {
          Array.from({ length: 3 }).map((_, i) => (
            <option value={i + 1}>{i + 1}학년</option>
          ))
        }
      </select>
    </div>
    <div class="mb-4">
      <label for="class" class="mb-2 block">반:</label>
      <select
        id="class"
        class="w-full border p-2 dark:bg-gray-800 dark:text-gray-100"
      >
        {
          Array.from({ length: 10 }).map((_, i) => (
            <option value={i + 1}>{i + 1}반</option>
          ))
        }
      </select>
    </div>
    <button
      id="fetch-timetable"
      class="flex items-center justify-center rounded bg-blue-500 p-2 text-white"
    >
      <span>시간표 조회</span>
      <svg
        id="loading-icon"
        class="ml-2 hidden h-5 w-5 animate-spin text-white"
        xmlns="http://www.w3.org/2000/svg"
        fill="none"
        viewBox="0 0 24 24"
      >
        <circle
          class="opacity-25"
          cx="12"
          cy="12"
          r="10"
          stroke="currentColor"
          stroke-width="4"></circle>
        <path
          class="opacity-75"
          fill="currentColor"
          d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
        ></path>
      </svg>
    </button>
    <div
      id="timetable-container"
      class="mt-4 rounded bg-gray-100 p-4 dark:bg-gray-800 dark:text-gray-300"
    >
      <table id="timetable" class="w-full border-collapse">
        <thead>
          <tr>
            <th class="border p-2">/</th>
            <th class="border p-2">월요일</th>
            <th class="border p-2">화요일</th>
            <th class="border p-2">수요일</th>
            <th class="border p-2">목요일</th>
            <th class="border p-2">금요일</th>
          </tr>
        </thead>
        <tbody>
          {
            Array.from({ length: 7 }).map((_, i) => (
              <tr>
                <td class="border p-2">{i + 1}교시</td>
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </main>
  <script>
    document.addEventListener("DOMContentLoaded", () => {
      const gradeElement = document.getElementById("grade");
      const classNumElement = document.getElementById("class");
      const fetchButtonElement = document.getElementById("fetch-timetable");
      const loadingIconElement = document.getElementById("loading-icon");
      let grade = localStorage.getItem("grade")
        ? parseInt(localStorage.getItem("grade") as string)
        : 1;
      let classNum = localStorage.getItem("classNum")
        ? parseInt(localStorage.getItem("classNum") as string)
        : 1;

      // @ts-ignore
      function updateGrade(event) {
        grade = parseInt(event.target.value);
        localStorage.setItem("grade", grade.toString());
      }

      // @ts-ignore
      function updateClassNum(event) {
        classNum = parseInt(event.target.value);
        localStorage.setItem("classNum", classNum.toString());
      }

      async function fetchTimetable() {
        try {
          if (fetchButtonElement) {
            (fetchButtonElement as HTMLButtonElement).disabled = true;
          }
          if (loadingIconElement) {
            loadingIconElement.classList.remove("hidden");
          }
          const response = await fetch(
            `https://api.INFO.KMHS.KR/timetable?grade=${grade}&classnum=${classNum}`,
          );
          if (!response.ok) {
            //@ts-ignore
            throw new Error("Network response was not ok");
          }
          const data = (await response.json()) as Record<string, string>;
          const timetableElement = document.querySelector("#timetable tbody");
          if (timetableElement) {
            const periods = [
              "1교시",
              "2교시",
              "3교시",
              "4교시",
              "5교시",
              "6교시",
              "7교시",
            ];
            const days = [
              "Monday",
              "Tuesday",
              "Wednesday",
              "Thursday",
              "Friday",
            ];

            // API 응답 데이터를 파싱하는 함수
            //@ts-ignore
            function parseTimeTableData(dayData) {
              if (!dayData || typeof dayData !== "string") return [];
              // "[1교시: 공수(권성*), 2교시: 통과(박가*), ...]" 형태를 파싱
              const cleanData = dayData.replace(/^\[|\]$/g, ""); // 앞뒤 대괄호 제거
              const periods = cleanData.split(", ");
              return periods.map((period) => {
                const match = period.match(/(\d+교시): (.+)/);
                if (match && match[2]) {
                  const subjectTeacher = match[2].trim();
                  if (subjectTeacher === "()") {
                    return {
                      subject: "없음",
                      teacher: "",
                    };
                  }
                  const teacherMatch = subjectTeacher.match(/^(.+)\((.+)\)$/);
                  if (teacherMatch) {
                    const subject = teacherMatch[1].trim();
                    const teacher = teacherMatch[2].trim().replace(/\*/g, "");
                    const substituteTeacherMatch =
                      subject.match(/^(.+)\((.+)\)$/);
                    if (teacher === "대체" && subject === "()") {
                      return {
                        subject: "없음",
                        teacher: "",
                        isSubstitute: true,
                      };
                    }
                    if (teacher === "대체" && substituteTeacherMatch) {
                      return {
                        subject: substituteTeacherMatch[1].trim(),
                        teacher: substituteTeacherMatch[2]
                          .trim()
                          .replace(/\*/g, ""),
                        isSubstitute: true,
                      };
                    }
                    return {
                      subject: subject === "()" ? "없음" : subject,
                      teacher: teacher,
                    };
                  }
                  return {
                    subject: subjectTeacher,
                    teacher: "",
                  };
                }
                return null;
              });
            }

            timetableElement.innerHTML = "";
            for (let i = 0; i < periods.length; i++) {
              const row = document.createElement("tr");
              const periodCell = document.createElement("td");
              periodCell.className = "border p-2 text-center";
              periodCell.textContent = periods[i];
              row.appendChild(periodCell);
              for (const day of days) {
                const timetableCell = document.createElement("td");
                timetableCell.className = "border p-2 text-center";

                const dayPeriods = parseTimeTableData(data[day]);
                const periodData = dayPeriods[i];

                timetableCell.innerHTML = periodData
                  ? `${periodData.isSubstitute ? '<div class="font-bold">대체</div>' : ""}<div>${periodData.subject}</div><div class="text-sm text-gray-500">${periodData.teacher}</div>`
                  : "";
                row.appendChild(timetableCell);
              }
              timetableElement.appendChild(row);
            }
          }
        } catch (error) {
          console.error("Error fetching timetable:", error);
        } finally {
          (fetchButtonElement as HTMLButtonElement).disabled = false;
          if (loadingIconElement) {
            loadingIconElement.classList.add("hidden");
          }
        }
      }

      if (gradeElement) {
        (gradeElement as unknown as HTMLSelectElement).value = grade.toString();
        gradeElement.addEventListener("change", updateGrade);
      }
      if (classNumElement) {
        (classNumElement as unknown as HTMLSelectElement).value =
          classNum.toString();
        classNumElement.addEventListener("change", updateClassNum);
      }
      if (fetchButtonElement) {
        fetchButtonElement.addEventListener("click", fetchTimetable);
      }

      // 페이지 로드 시 로컬 스토리지에 값이 있으면 시간표 조회
      if (localStorage.getItem("grade") != null) {
        grade = parseInt(localStorage.getItem("grade") as string);
        classNum = parseInt(localStorage.getItem("classNum") as string);
        fetchTimetable();
      }
    });
  </script>
</Layout>
