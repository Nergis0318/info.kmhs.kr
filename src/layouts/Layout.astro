---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;

import { Icon } from "astro-icon/components";

const year = new Date().getFullYear();
---

<html lang="kr">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="author" content="Your Name" />
    <meta name="keywords" content="astro, academic calendar, school schedule" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://INFO.KMHS.KR" />
    <meta property="og:image" content="https://INFO.KMHS.KR/pwa.png" />
    <link rel="icon" type="image/webp" href="/favicon.webp" />
    <link rel="manifest" href="/manifest.json" />
    <meta name="google-adsense-account" content="ca-pub-6290342471056589" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;800&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>

    <script is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            // eslint-disable-next-line prefer-rest-params
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "ozd18f4h4a");
    </script>

    <script is:inline>
      if ("serviceWorker" in navigator) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/service-worker.js").then(
            (registration) => {
              console.log(
                "ServiceWorker registration successful with scope: ",
                registration.scope,
              );
            },
            (err) => {
              console.log("ServiceWorker registration failed: ", err);
            },
          );
        });
      }
    </script>
  </head>

  <body>
    <nav class="navbar">
      <ul class="navbar-menu">
        <li class="navbar-home" style="position: absolute; left: 0;">
          <a href="/">
            <Icon name="mdi:home" class="home-icon" />
          </a>
        </li>
        <li>
          <a href="/academic_calendar"
            ><Icon name="icon-park-twotone:degree-hat" class="home-icon" /></a
          >
        </li>
        <li>
          <a href="/meal"
            ><Icon
              name="fluent-emoji-high-contrast:fork-and-knife-with-plate"
              class="home-icon"
            /></a
          >
        </li>
        <li>
          <a href="/timetable"
            ><Icon name="mdi:timetable" class="home-icon" /></a
          >
        </li>
        <li>
          <a href="/url"
            ><Icon name="mdi:link-box-variant-outline" class="home-icon" /></a
          >
        </li>
        <li>
          <a href="/tool"
            ><Icon name="mdi:toolbox-outline" class="home-icon" /></a
          >
        </li>
        <li>
          <a href="/about"
            ><Icon name="mdi:about-circle-outline" class="home-icon" /></a
          >
        </li>
      </ul>
    </nav>

    <slot />

    <footer class="mt-8 py-4">
      <div class="container mx-auto text-center">
        <p>&copy; {year} <strong>Nergis</strong>. All rights reserved.</p>
        <p>
          Made with &hearts; and <a
            href="https://astro.build/"
            class="footer-link">Astro</a
          >
        </p>
        <a
          href="https://github.com/Nergis0318/info.kmhs.kr"
          class="footer-link">GitHub Repository</a
        >
      </div>
    </footer>
  </body>
</html>

<style is:global>
  .navbar {
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 1rem;
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .navbar-menu {
    list-style: none;
    display: flex;
    justify-content: center;
    margin: 0;
    padding: 0;
  }

  .navbar-home {
    margin-right: auto;
  }

  .navbar-menu li {
    margin: 0 1rem;
  }

  .navbar-menu a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    transition: color 0.2s ease;
    display: block;
    padding: 0.25rem;
    border-radius: 6px;
  }

  .navbar-menu a:hover {
    color: #fff;
  }

  .navbar-menu a.active {
    color: var(--primary, #883aea);
  }

  .home-icon {
    width: 24px;
    height: 24px;
  }

  /* Layout footer */
  footer {
    background: rgba(0, 0, 0, 0.3);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: rgba(255, 255, 255, 0.4);
    padding: 2rem;
    text-align: center;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    font-size: 0.875rem;
  }

  footer strong {
    color: #fff;
    font-weight: 600;
  }

  footer .footer-link {
    color: var(--primary, #883aea);
    text-decoration: none;
    font-weight: 500;
    transition:
      color 0.2s,
      text-shadow 0.2s;
  }

  footer .footer-link:hover {
    color: #fff;
    text-shadow: 0 0 12px var(--primary, #883aea);
  }
</style>
