{
  "compatibility_date": "2026-05-02",
  "compatibility_flags": ["global_fetch_strictly_public"],
  "name": "info-kmhs-kr",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
    "traces": {
      "enabled": true,
    },
  },
  "routes": [
    {
      "pattern": "info.kmhs.kr",
      "custom_domain": true,
    },
  ],
}
